    "build:clean": "npm run clean && next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@upstash/qstash": "^2.11.1",
    "next": "^15.3.3",
    "openai": "^6.44.0",
    "react": "^19.1.0",
