# ── Google OAuth2 ──────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# Must match the redirect URI you added in the Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback
# Obtained by running:  npm run setup-oauth
GOOGLE_REFRESH_TOKEN=your_refresh_token_here

# ── Calendar settings ──────────────────────────────────────────────────────────
# "primary" uses the calendar owner's main calendar; or supply a calendar ID
CALENDAR_ID=primary
TIMEZONE=America/New_York
APPOINTMENT_DURATION_MINUTES=60
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=17

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
